# CREAUNA — Variables de entorno (copiar a .env.local en desarrollo / Vercel en producción)

# Sitio
NEXT_PUBLIC_SITE_URL=https://creauna.vercel.app

# Desactivar barra flotante de Vercel en preview/producción (añadir en Vercel → Environment Variables)
VERCEL_PREVIEW_FEEDBACK_ENABLED=0

# IA — al menos una activa
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Qwen (DashScope / Model Studio) — priorizado para HTML largo de Studio
# Clave: https://www.alibabacloud.com/help/en/model-studio/get-api-key
QWEN_API_KEY=
# DASHSCOPE_API_KEY=   # alias de QWEN_API_KEY
# Modelo: en muchas cuentas free/trial funciona «qwen-plus».
# «qwen3.7-plus» puede devolver AccessDenied.Unpurchased si no está activado en DashScope.
# CREAUNA prueba varios modelos en cascada si el preferido falla.
QWEN_MODEL=qwen-plus
# Internacional (Singapur): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# China (Pekín): https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Si tu consola te da un host con WorkspaceId, pégalo aquí en su lugar.GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ping en vivo — GET /api/ai/ping (admin o ?secret=)
AI_PING_SECRET=

# Manus — tareas async largas (open.manus.ai), opcional
MANUS_API_KEY=

# fal.ai — imágenes hero/galería cuando Unsplash/Pexels no bastan
FAL_KEY=
# FAL_HERO_MODEL=fal-ai/flux/schnell
# FAL_GALLERY_MODEL=fal-ai/flux/schnell
# CREAUNA_FAL_IMAGES=0

# Gemini — también puede generar imágenes si fal falla (modelo imagen)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Email (Resend) — cuando el dominio esté Verified en resend.com/domains
RESEND_API_KEY=
RESEND_FROM_DOMAIN=ramondelpozorott.es
CONTACT_FROM_EMAIL=CREAUNA <contacto@ramondelpozorott.es>
CONTACT_TO_EMAIL=info@ramondelpozorott.es

# Stripe — activar cuando haya cuenta empresarial
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Auth
CREAUNA_DEMO_AUTH=false
CREAUNA_AUTH_SECRET=cambiar-en-produccion
CREAUNA_ADMIN_EMAIL=info@ramondelpozorott.es
# Contraseña maestra superadmin: crea/actualiza la cuenta al iniciar sesión (Vercel → Production)
CREAUNA_ADMIN_PASSWORD=

# Studio Ferrari — flags (true por defecto si no se definen)
# CREAUNA_STUDIO_SNAPSHOTS=false
# CREAUNA_STUDIO_IMPACT_PREVIEW=false
# CREAUNA_STUDIO_VALIDATION=false
# CREAUNA_STUDIO_AUDIT=false

# Base de datos (Neon Postgres en producción y local)
# Pooled (Vercel): postgresql://USER:PASS@HOST/creauna?sslmode=require
# Direct (prisma db push local): usar la URL "Direct connection" de Neon
DATABASE_URL=
