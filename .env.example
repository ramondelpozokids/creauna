# CREAUNA — Variables de entorno

# URL pública del sitio (Vercel)
NEXT_PUBLIC_SITE_URL=https://creauna.vercel.app

# ── IA: 4 motores (recomendado Gemini + Claude) ──────────────────
# Motor Visual + Código → Gemini (gratis en Google AI Studio)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Motor Redacción + UX → Claude (console.anthropic.com)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Motor de Código → OpenAI / ChatGPT (platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Respaldo gratuito opcional (console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Comprobación en vivo de proveedores (GET /api/ai/ping) — admin o ?secret=
AI_PING_SECRET=

# Manus — agente async para tareas complejas (open.manus.ai), NO preview instantáneo
MANUS_API_KEY=

# Arena/LMSYS — NO tiene API oficial. No usar en producción.

# ── Stripe (cuando tengas empresa) ─────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email — Resend (verificar dominio para enviar a info@ramondelpozorott.es)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@ramondelpozorott.es
RESEND_FROM_DOMAIN=ramondelpozorott.es
CONTACT_FROM_EMAIL=CREAUNA <contacto@ramondelpozorott.es>

# ── Auth ─────────────────────────────────────────────────────────
CREAUNA_AUTH_SECRET=cambia-este-secreto-en-produccion
CREAUNA_DEMO_AUTH=true
