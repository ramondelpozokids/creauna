generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  credits      Int           @default(15)
  role         String        @default("user")
  createdAt    DateTime      @default(now())
  projects     Project[]
  creditLogs   CreditLog[]
}

model Project {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  templateSlug String?
  lang         String               @default("es")
  sections     String
  changeLog    String               @default("[]")
  messages     String               @default("[]")
  status       String               @default("draft")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  snapshots    ProjectSnapshot[]
  audits       ProjectChangeAudit[]

  @@index([userId])
}

model ProjectSnapshot {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String
  versionNumber Int
  sections      String
  changeLog     String   @default("[]")
  action        String
  prompt        String?
  sectionId     Int?
  label         String?
  createdAt     DateTime @default(now())

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@index([userId])
}

model ProjectChangeAudit {
  id                 String   @id @default(cuid())
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId             String?
  ipHash             String?
  action             String
  prompt             String?
  sectionId          Int?
  affectedSectionIds String   @default("[]")
  source             String
  motorsUsed         String   @default("[]")
  validationOk       Boolean  @default(true)
  validationErrors   String   @default("[]")
  diffSummary        String?
  durationMs         Int?
  snapshotId         String?
  createdAt          DateTime @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipHash    String?
  delta     Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([ipHash])
}

model GuestUsage {
  id      String @id @default(cuid())
  ipHash  String @unique
  credits Int    @default(15)
}
